const currentModels = [
  { name: 'Claude Sonnet 5', href: 'https://openrouter.ai/anthropic/claude-sonnet-5' },
  { name: 'GPT-5.6 Sol', href: 'https://openrouter.ai/openai/gpt-5.6-sol' },
  { name: 'Gemini 3.5 Flash', href: 'https://openrouter.ai/google/gemini-3.5-flash' },
  { name: 'Kimi K3', href: 'https://openrouter.ai/moonshotai/kimi-k3' },
  { name: 'DeepSeek V4 Pro', href: 'https://openrouter.ai/deepseek/deepseek-v4-pro' },
  { name: 'Qwen3.7 Max', href: 'https://openrouter.ai/qwen/qwen3.7-max' },
