---
const installCommand = 'curl -fsSL https://raw.githubusercontent.com/owainlewis/neo/main/install.sh | bash';
---

<div class="neo-home">
  <section class="neo-hero" aria-labelledby="neo-title">
    <div class="neo-hero-copy">
      <h1 id="neo-title">A coding agent you can trust.</h1>
      <p class="neo-hero-lede">
        Neo turns long engineering tasks into a visible workflow. It keeps the plan, tool activity,
        agents, and results in view while it works.
      </p>
      <div class="neo-actions">
        <a class="neo-button neo-button-primary" href="/docs/install/">Install Neo</a>
        <a class="neo-text-link" href="https://github.com/owainlewis/neo">View on GitHub <span aria-hidden="true">↗</span></a>
      </div>
      <div class="neo-install" role="group" aria-label="Install command">
        <code>{installCommand}</code>
        <button type="button" data-copy-install data-command={installCommand} aria-label="Copy install command">
          <svg class="copy-icon" viewBox="0 0 20 20" aria-hidden="true"><rect x="6" y="6" width="10" height="10" rx="2"></rect><path d="M13 6V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h1"></path></svg>
          <svg class="check-icon" viewBox="0 0 20 20" aria-hidden="true"><path d="m4 10 4 4 8-9"></path></svg>
        </button>
        <span class="neo-copy-status" data-copy-status aria-live="polite"></span>
      </div>
    </div>

    <div class="neo-hero-preview" role="group" aria-label="Neo working through an example task">
      <div class="neo-preview-bar">
        <span>neo / billing-api</span>
        <span><i></i> working</span>
      </div>
      <div class="neo-preview-body">
        <div class="neo-preview-title">
          <div><span>Active workflow</span><strong>Fix duplicate invoice retries</strong></div>
          <small>3 / 4</small>
        </div>
        <ol class="neo-preview-list">
          <li class="complete"><span>✓</span><div><strong>Trace retry path</strong><small>9 files read</small></div></li>
          <li class="complete"><span>✓</span><div><strong>Add idempotency guard</strong><small>2 files changed</small></div></li>
          <li class="active"><span><i></i></span><div><strong>Test concurrent delivery</strong><small>go test ./internal/billing/...</small></div></li>
          <li><span></span><div><strong>Review the diff</strong><small>waiting</small></div></li>
        </ol>
        <div class="neo-preview-agent">
          <span>review agent</span>
          <strong>Checking race conditions</strong>
          <small>12s</small>
        </div>
      </div>
      <div class="neo-preview-footer"><span>2 agents</span><span>claude-opus-4-8</span></div>
    </div>
  </section>

  <section class="neo-product" aria-labelledby="workflow-title">
    <div class="neo-product-heading">
      <div>
        <p class="neo-label">A task in Neo</p>
        <h2 id="workflow-title">The work stays legible.</h2>
      </div>
      <p>A live checklist makes a long-running task easy to follow, question, and review.</p>
    </div>

    <div class="neo-workflow" role="group" aria-label="Example Neo workflow">
      <div class="neo-workflow-top">
        <span>payments-api</span>
        <span class="neo-mode"><i></i> ask mode</span>
      </div>
      <div class="neo-request">
        <span aria-hidden="true">›</span>
        <p>Harden webhook verification and prove it works</p>
      </div>
      <div class="neo-plan">
        <div class="neo-plan-meta">
          <span>Plan</span>
          <span>3 of 4 complete</span>
        </div>
        <ol>
          <li class="done">
            <span class="neo-check">✓</span>
            <div><strong>Trace the request path</strong><small>Read 8 files</small></div>
          </li>
          <li class="done">
            <span class="neo-check">✓</span>
            <div><strong>Implement signature validation</strong><small>Edited 3 files</small></div>
          </li>
          <li class="active">
            <span class="neo-check"><i></i></span>
            <div>
              <strong>Test failure modes</strong><small>Running go test ./internal/webhook/...</small>
              <div class="neo-agent"><span>review agent</span><span>checking replay protection</span></div>
            </div>
          </li>
          <li>
            <span class="neo-check"></span>
            <div><strong>Review the final diff</strong><small>Waiting on tests</small></div>
          </li>
        </ol>
      </div>
      <div class="neo-proof"><span>✓</span><code>ok github.com/acme/payments/internal/webhook</code><small>0.84s</small></div>
    </div>
  </section>

  <section class="neo-intro" aria-labelledby="difference-title">
    <p class="neo-label">Why Neo</p>
    <h2 id="difference-title">Serious engineering is a sequence of decisions, not a magic prompt.</h2>
    <p>
      Most agents collapse that sequence into a stream of text. Neo gives it structure. Plans stay
      visible, risky changes require the permission mode you choose, and results come back with evidence.
    </p>
  </section>

  <section class="neo-principles" aria-label="Neo principles">
    <article>
      <span>01</span>
      <h3>Visible by default</h3>
      <p>The checklist, tool activity, subagents, and results stay in view while Neo works.</p>
    </article>
    <article>
      <span>02</span>
      <h3>Control stays yours</h3>
      <p>Choose ask, trusted, or read-only mode. Ask mode previews file changes before they happen.</p>
    </article>
    <article>
      <span>03</span>
      <h3>Bring your model</h3>
      <p>Use Anthropic, OpenAI, OpenRouter, or Gemini without changing the way you work.</p>
    </article>
  </section>

  <section class="neo-orchestration" aria-labelledby="orchestration-title">
    <div class="neo-orchestration-copy">
      <p class="neo-label">Orchestration</p>
      <h2 id="orchestration-title">One plan. Focused agents.</h2>
      <p>
        Neo can give bounded pieces of work to fresh subagents, follow their progress, and bring
        their findings back to the main task. The coordinator remains responsible for the result.
      </p>
      <a class="neo-text-link" href="/docs/reference/guides/agent-loop/">How the agent loop works <span aria-hidden="true">→</span></a>
    </div>
    <div class="neo-agents" aria-label="Example delegated work">
      <div class="neo-coordinator-row"><span>Neo</span><strong>Harden webhook verification</strong><small>coordinator</small></div>
      <div class="neo-agent-row"><span>01</span><strong>Trace request path</strong><small class="complete">complete</small></div>
      <div class="neo-agent-row"><span>02</span><strong>Implement validation</strong><small class="working">working</small></div>
      <div class="neo-agent-row"><span>03</span><strong>Review failure modes</strong><small>queued</small></div>
      <p>Bounded depth, fan-out, runtime, and agent count.</p>
    </div>
  </section>

  <section class="neo-foundation" aria-labelledby="foundation-title">
    <div>
      <p class="neo-label">The foundation</p>
      <h2 id="foundation-title">Small core.<br />Serious capability.</h2>
    </div>
    <dl>
      <div><dt>One binary</dt><dd>No runtime to assemble. Install it and work.</dd></div>
      <div><dt>Local sessions</dt><dd>Session files are stored locally. Context goes to your chosen model provider.</dd></div>
      <div><dt>Open source</dt><dd>Inspect the harness you trust with your code.</dd></div>
      <div><dt>No telemetry</dt><dd>Neo does not phone home with product analytics.</dd></div>
    </dl>
  </section>

  <section class="neo-final" aria-labelledby="final-title">
    <p class="neo-label">Neo Harness</p>
    <h2 id="final-title">Put the work in the open.</h2>
    <p>Start with one binary and the model provider you already use.</p>
    <div class="neo-actions">
      <a class="neo-button neo-button-primary" href="/docs/install/">Install Neo</a>
      <a class="neo-text-link" href="/docs/quick-start/">Read the quick start <span aria-hidden="true">→</span></a>
    </div>
  </section>
</div>

<script>
  const button = document.querySelector('[data-copy-install]');
  const copyStatus = document.querySelector('[data-copy-status]');

  const copyText = async (text: string) => {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      const input = document.createElement('textarea');
      input.value = text;
      input.setAttribute('readonly', '');
      input.style.position = 'fixed';
      input.style.opacity = '0';
      document.body.append(input);
      input.select();
      const copied = document.execCommand('copy');
      input.remove();
      return copied;
    }
  };

  button?.addEventListener('click', async () => {
    const command = button.getAttribute('data-command') ?? '';
    if (await copyText(command)) {
      button.classList.add('copied');
      button.setAttribute('aria-label', 'Install command copied');
      if (copyStatus) copyStatus.textContent = 'Install command copied.';
      window.setTimeout(() => {
        button.classList.remove('copied');
        button.setAttribute('aria-label', 'Copy install command');
        if (copyStatus) copyStatus.textContent = '';
      }, 1800);
    } else {
      button.setAttribute('aria-label', 'Copy failed. Select the command manually.');
      if (copyStatus) copyStatus.textContent = 'Copy failed. Select the command manually.';
    }
  });
</script>
