  coordinator: { owner: 'Neo', task: 'Harden webhook verification', status: 'coordinator' },
  rows: [
    { number: '01', label: 'Trace request path', status: 'complete', statusClass: 'complete' },
    { number: '02', label: 'Check failure modes', status: 'working', statusClass: 'working' },
    { number: '03', label: 'Review test coverage', status: 'queued' },
  ],
  note: 'Depth, fan-out, runtime, and agent count stay capped.',
