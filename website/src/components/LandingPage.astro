const productWorkflow = {
  variant: 'product' as const,
  project: '~/Code/payments-api · main',
  mode: 'working',
  request: 'Fix reported webhook bugs and ship the change',
  progress: '2 of 9',
  items: [
    { label: 'Create the issue', detail: 'Created GitHub issue #210', status: 'done' as const },
    { label: 'Create an isolated branch and worktree', detail: 'Running git worktree add', status: 'active' as const },
    { label: 'Trace and fix the bugs', detail: '' },
    { label: 'Review the diff with a subagent', detail: '' },
    { label: 'Run focused tests', detail: '' },
    { label: 'Open the pull request', detail: '' },
    { label: 'Watch CI and code review', detail: '' },
    { label: 'Address valid feedback', detail: '' },
    { label: 'Merge the change', detail: '' },
