---
import DemoWorkflow from './DemoWorkflow.astro';

const installCommand = 'curl -fsSL https://raw.githubusercontent.com/owainlewis/neo/main/install.sh | bash';

const heroWorkflow = {
  variant: 'hero' as const,
  project: 'neo / billing-api',
  title: 'Fix duplicate invoice retries',
  progress: '3 / 4',
  items: [
    { label: 'Trace retry path', detail: '9 files read', status: 'complete' as const },
    { label: 'Add idempotency guard', detail: '2 files changed', status: 'complete' as const },
    { label: 'Test concurrent delivery', detail: 'go test ./internal/billing/...', status: 'active' as const },
    { label: 'Review the diff', detail: 'waiting' },
  ],
  agent: { label: 'review agent', detail: 'Checking race conditions', elapsed: '12s' },
  footer: ['2 agents', 'claude-opus-4-8'],
};

const productWorkflow = {
  variant: 'product' as const,
  project: 'payments-api',
  mode: 'ask mode',
  request: 'Harden webhook verification and prove it works',
  progress: '3 of 4 complete',
  items: [
    { label: 'Trace the request path', detail: 'Read 8 files', status: 'done' as const },
    { label: 'Implement signature validation', detail: 'Edited 3 files', status: 'done' as const },
    { label: 'Test failure modes', detail: 'Running go test ./internal/webhook/...', status: 'active' as const },
    { label: 'Review the final diff', detail: 'Waiting on tests' },
  ],
  agent: { label: 'review agent', detail: 'checking replay protection' },
  proof: { command: 'ok github.com/acme/payments/internal/webhook', elapsed: '0.84s' },
};

const agentWorkflow = {
  variant: 'agents' as const,
  coordinator: { owner: 'Neo', task: 'Harden webhook verification', status: 'coordinator' },
  rows: [
    { number: '01', label: 'Trace request path', status: 'complete', statusClass: 'complete' },
    { number: '02', label: 'Implement validation', status: 'working', statusClass: 'working' },
    { number: '03', label: 'Review failure modes', status: 'queued' },
  ],
  note: 'Depth, fan-out, runtime, and agent count are all capped.',
};
---

<div class="neo-home not-content">
  <section class="neo-hero" aria-labelledby="neo-title">
    <div class="neo-hero-copy">
      <h1 id="neo-title">A coding agent you can trust.</h1>
      <p class="neo-hero-lede">
        Neo runs long engineering tasks in the open: the plan, the permissions, and the proof stay
        in front of you. Built for engineers who answer for what ships.
      </p>
      <div class="neo-actions">
        <a class="neo-button neo-button-primary" href="/docs/install/">Install Neo</a>
        <a class="neo-text-link" href="https://github.com/owainlewis/neo">View on GitHub <span aria-hidden="true">↗</span></a>
      </div>
      <div class="neo-install" role="group" aria-label="Install command">
        <code>{installCommand}</code>
        <button type="button" data-copy-install data-command={installCommand} aria-label="Copy install command">
          <svg class="copy-icon" viewBox="0 0 20 20" aria-hidden="true"><rect x="6" y="6" width="10" height="10" rx="2"></rect><path d="M13 6V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h1"></path></svg>
          <svg class="check-icon" viewBox="0 0 20 20" aria-hidden="true"><path d="m4 10 4 4 8-9"></path></svg>
        </button>
        <span class="neo-copy-status" data-copy-status aria-live="polite"></span>
      </div>
    </div>

    <DemoWorkflow {...heroWorkflow} />
  </section>

  <section class="neo-product" aria-labelledby="workflow-title">
    <div class="neo-product-heading">
      <div>
        <p class="neo-label">A task in Neo</p>
        <h2 id="workflow-title">The work stays legible.</h2>
      </div>
      <p>A live checklist makes a long-running task easy to follow, question, and review.</p>
    </div>

    <DemoWorkflow {...productWorkflow} />
  </section>

  <section class="neo-intro" aria-labelledby="difference-title">
    <p class="neo-label">Why Neo</p>
    <h2 id="difference-title">Serious engineering is a sequence of decisions, not a magic prompt.</h2>
    <p>
      Most agents bury those decisions in a scroll of text. Neo keeps them in the open. The plan
      stays on screen, changes follow the permission mode you set, and results come back with the
      test run that proves them.
    </p>
  </section>

  <section class="neo-principles" aria-label="Neo principles">
    <article>
      <span>01</span>
      <h3>Visible by default</h3>
      <p>Every step, tool call, and subagent shows up as it happens. Nothing runs off screen.</p>
    </article>
    <article>
      <span>02</span>
      <h3>Control stays yours</h3>
      <p>Choose ask, trusted, or read-only mode. Ask mode previews file changes before they happen.</p>
    </article>
    <article>
      <span>03</span>
      <h3>Bring your model</h3>
      <p>Neo works the same with Anthropic, OpenAI, Gemini, or OpenRouter. Switch with a config change.</p>
    </article>
  </section>

  <section class="neo-orchestration" aria-labelledby="orchestration-title">
    <div class="neo-orchestration-copy">
      <p class="neo-label">Orchestration</p>
      <h2 id="orchestration-title">One plan. Focused agents.</h2>
      <p>
        Neo hands well-scoped pieces of a task to fresh subagents, follows their progress, and
        folds their findings back into the main plan. One coordinator owns the result.
      </p>
      <a class="neo-text-link" href="/docs/reference/guides/agent-loop/">How the agent loop works <span aria-hidden="true">→</span></a>
    </div>
    <DemoWorkflow {...agentWorkflow} />
  </section>

  <section class="neo-foundation" aria-labelledby="foundation-title">
    <div>
      <p class="neo-label">The foundation</p>
      <h2 id="foundation-title">Small core.<br />Nothing hidden.</h2>
    </div>
    <dl>
      <div><dt>One binary</dt><dd>No runtime to assemble. Install it and work.</dd></div>
      <div><dt>Local sessions</dt><dd>Sessions live on your disk. Context goes only to the model provider you choose.</dd></div>
      <div><dt>Open source</dt><dd>Inspect the harness you trust with your code.</dd></div>
      <div><dt>No telemetry</dt><dd>Neo does not phone home with product analytics.</dd></div>
    </dl>
  </section>

  <section class="neo-final" aria-labelledby="final-title">
    <p class="neo-label">Neo Harness</p>
    <h2 id="final-title">Put the work in the open.</h2>
    <p>Start with one binary and the model provider you already use.</p>
    <div class="neo-actions">
      <a class="neo-button neo-button-primary" href="/docs/install/">Install Neo</a>
      <a class="neo-text-link" href="/docs/quick-start/">Read the quick start <span aria-hidden="true">→</span></a>
    </div>
  </section>
</div>

<script>
  const button = document.querySelector('[data-copy-install]');
  const copyStatus = document.querySelector('[data-copy-status]');

  const copyText = async (text: string) => {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      const input = document.createElement('textarea');
      input.value = text;
      input.setAttribute('readonly', '');
      input.style.position = 'fixed';
      input.style.opacity = '0';
      document.body.append(input);
      input.select();
      const copied = document.execCommand('copy');
      input.remove();
      return copied;
    }
  };

  button?.addEventListener('click', async () => {
    const command = button.getAttribute('data-command') ?? '';
    if (await copyText(command)) {
      button.classList.add('copied');
      button.setAttribute('aria-label', 'Install command copied');
      if (copyStatus) copyStatus.textContent = 'Install command copied.';
      window.setTimeout(() => {
        button.classList.remove('copied');
        button.setAttribute('aria-label', 'Copy install command');
        if (copyStatus) copyStatus.textContent = '';
      }, 1800);
    } else {
      button.setAttribute('aria-label', 'Copy failed. Select the command manually.');
      if (copyStatus) copyStatus.textContent = 'Copy failed. Select the command manually.';
    }
  });
</script>
