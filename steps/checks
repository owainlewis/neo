#!/usr/bin/env bash
# Script step: invariants, not opinions. Free, deterministic.
# Ignores stdin; checks the working tree it runs in.
set -u
fail=0
unformatted=$(gofmt -l . 2>/dev/null)
if [ -n "$unformatted" ]; then echo "gofmt needed: $unformatted"; fail=1; fi
go vet ./... || fail=1
go test ./... || fail=1
if [ "$fail" -eq 0 ]; then echo "ALL CHECKS GREEN"; else echo "CHECKS FAILING"; fi
exit "$fail"
